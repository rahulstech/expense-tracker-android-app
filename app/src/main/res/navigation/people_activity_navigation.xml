<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/people_activity_navigation"
    app:startDestination="@id/people_list">

    <fragment android:id="@+id/people_list"
        android:name="dreammaker.android.expensetracker.fragment.PersonsList"
        tools:layout="@layout/list_content">

        <action android:id="@+id/action_personsList_to_inputPerson"
            app:destination="@id/input_person"/>
        <action android:id="@+id/action_personsList_to_transactionsList"
            app:destination="@id/transactions_list"/>
    </fragment>

    <fragment android:id="@+id/transactions_list"
        android:name="dreammaker.android.expensetracker.fragment.TransactionsList"
        tools:layout="@layout/list_content">

    </fragment>

    <fragment android:id="@+id/input_person"
        android:name="dreammaker.android.expensetracker.fragment.InputPerson"
        tools:layout="@layout/input_person">

    </fragment>

</navigation>