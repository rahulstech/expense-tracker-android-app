<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:startDestination="@id/home">

    <!-- Fragment Home -->
    <fragment
        android:id="@+id/home"
        android:name="dreammaker.android.expensetracker.fragment.Home"
        android:label="@string/app_name"
        tools:layout="@layout/home">

        <action android:id="@+id/home_to_activity_account"
            app:destination="@id/activity_account"/>

        <action android:id="@+id/home_to_activity_people"
            app:destination="@id/activity_people"/>

    </fragment>

    <activity android:id="@+id/activity_account"
        android:name="dreammaker.android.expensetracker.activity.ActivityAccount"
        tools:layout="@layout/activity_account"/>

    <activity android:id="@+id/activity_people"
        android:name="dreammaker.android.expensetracker.activity.ActivityPeople"
        tools:layout="@layout/activity_people"/>

</navigation>