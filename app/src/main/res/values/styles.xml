<resources>

    <style name="Widget.AppTheme.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Widget.AppTheme.FloatingActionButton" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="elevation">10dp</item>
    </style>

    <style name="Widget.AppTheme.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">

    </style>

    <style name="Widget.AppTheme.TileCard" parent="Widget.MaterialComponents.CardView">
        <item name="shapeAppearance">@style/ShapeAppearance.AppTheme.TilesSmall</item>
        <item name="useCompatPadding">true</item>
    </style>

    <style name="Widget.AppTheme.TileCard.Small">
        <item name="contentPadding">@dimen/tile_padding_small</item>
        <item name="cardElevation">@dimen/tile_elevation_small</item>
        <item name="android:layout_marginTop">@dimen/tile_margin_small</item>
        <item name="android:layout_marginLeft">@dimen/tile_margin_small</item>
        <item name="android:layout_marginRight">@dimen/tile_margin_small</item>
        <item name="android:layout_marginBottom">@dimen/tile_margin_small</item>
        <item name="shapeAppearance">@style/ShapeAppearance.AppTheme.TilesSmall</item>
    </style>

    <style name="Widget.AppTheme.TileCard.Medium">
        <item name="contentPadding">@dimen/tile_padding_small</item>
        <item name="cardElevation">@dimen/tile_elevation_medium</item>
        <item name="android:layout_marginTop">@dimen/tile_margin_medium</item>
        <item name="android:layout_marginLeft">@dimen/tile_margin_small</item>
        <item name="android:layout_marginRight">@dimen/tile_margin_small</item>
        <item name="android:layout_marginBottom">@dimen/tile_margin_medium</item>
        <item name="shapeAppearance">@style/ShapeAppearance.AppTheme.TilesMedium</item>
    </style>

    <style name="Widget.AppTheme.TileCard.Large">
        <item name="contentPadding">@dimen/tile_padding_medium</item>
        <item name="cardElevation">@dimen/tile_elevation_medium</item>
        <item name="android:layout_marginTop">@dimen/tile_margin_medium</item>
        <item name="android:layout_marginLeft">@dimen/tile_margin_medium</item>
        <item name="android:layout_marginRight">@dimen/tile_margin_medium</item>
        <item name="android:layout_marginBottom">@dimen/tile_margin_medium</item>
        <item name="shapeAppearance">@style/ShapeAppearance.AppTheme.TilesLarge</item>
    </style>

    <style name="Widget.AppTheme.ActionButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:maxWidth">64dp</item>
        <item name="iconGravity">textTop</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:layout_marginLeft">8dp</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:layout_marginRight">8dp</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="shapeAppearance">@null</item>
        <item name="shapeAppearanceOverlay">@null</item>
        <item name="android:textAppearance">@style/TextAppearance.AppTheme.ActionButton</item>
        <item name="maxLines">2</item>
        <item name="android:maxLines">2</item>
        <item name="singleLine">false</item>
        <item name="android:singleLine">false</item>
    </style>

    <!-- TODO: action mode background not working -->
    <style name="AppTheme.ActionMode" parent="Widget.AppCompat.ActionMode">
        <item name="actionModeBackground">?attr/colorPrimary</item>
        <item name="android:actionModeBackground">?attr/colorPrimary</item>
    </style>

    <style name="AppTheme.ActionMode.Popup" parent="AppTheme.ActionBar.Popup"/>

    <style name="Widget.AppTheme.CheckableChip" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.AppTheme.Chip</item>
        <item name="chipIconEnabled">true</item>
        <item name="chipIconVisible">true</item>
        <item name="checkedIcon">@null</item>
        <item name="iconStartPadding">4dp</item>
        <item name="iconEndPadding">4dp</item>
        <item name="checkedIconEnabled">false</item>
        <item name="checkedIconVisible">false</item>
        <item name="closeIcon">@null</item>
        <item name="closeIconEnabled">false</item>
        <item name="closeIconVisible">false</item>
        <item name="rippleColor">@null</item>
        <item name="chipIconTint">@color/checkable_chip_icon_tint</item>
        <item name="android:textColor">@color/checkable_chip_icon_tint</item>
        <item name="chipBackgroundColor">@color/checkable_chip_background_color</item>
    </style>
    <style name="Widget.AppTheme.EntryChip" parent="Widget.MaterialComponents.Chip.Entry">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.AppTheme.Chip</item>
        <item name="chipIconEnabled">true</item>
        <item name="chipIconVisible">true</item>
        <item name="chipIcon">@null</item>
        <item name="chipIconSize">24dp</item>
        <item name="checkedIconVisible">false</item>
        <item name="checkedIconEnabled">false</item>
        <item name="checkedIcon">@null</item>
        <item name="chipBackgroundColor">@color/light_blue_A200</item>
        <item name="closeIconVisible">true</item>
        <item name="closeIconEnabled">true</item>
        <item name="closeIconTint">@android:color/white</item>
        <item name="android:textColor">@android:color/white</item>
    </style>
</resources>
