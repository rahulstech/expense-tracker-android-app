<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimary</item>
        <item name="colorAccent">@color/colorAccent</item>

        <item name="actionModeStyle">@style/AppTheme.ActionMode</item>
        <item name="windowActionModeOverlay">true</item>
        <item name="floatingActionButtonStyle">@style/Widget.AppTheme.FloatingActionButton</item>

        <item name="chipWithImageStyle">@style/Widget.AppTheme.EntryChip</item>
    </style>

    <!-- NoActionBar Theme -->
    <style name="AppTheme.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- FullScreen Theme -->
    <style name="AppTheme.NoActionBar.FullScreen">
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- ActionBar Theme -->
    <style name="AppTheme.ActionBar" parent="ThemeOverlay.MaterialComponents.Dark.ActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimary</item>
        <item name="colorAccent">@color/colorAccent</item>

        <item name="colorSurface">?attr/colorPrimary</item>
        <item name="android:colorBackground">?attr/colorPrimary</item>
        <item name="android:windowBackground">?attr/colorPrimary</item>
        <item name="android:colorForegroundInverse">?attr/colorPrimary</item>
        <item name="colorOnSurface">?attr/colorOnPrimary</item>
    </style>

    <!-- ActionBar Popup Theme -->
    <style name="AppTheme.ActionBar.Popup" parent="ThemeOverlay.MaterialComponents.Light"/>
</resources>