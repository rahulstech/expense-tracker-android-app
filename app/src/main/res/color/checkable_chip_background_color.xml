<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 24% opacity -->
    <item android:color="@color/light_blue_A200" android:state_enabled="true" android:state_selected="true"/>
    <item android:color="@color/light_blue_A200" android:state_enabled="true" android:state_checked="true"/>
    <!-- 12% of 87% opacity -->
    <item android:alpha="0.15" android:color="?attr/colorOnSurface" android:state_enabled="true"/>
    <item android:alpha="0.20" android:color="?attr/colorOnSurface"/>
</selector>