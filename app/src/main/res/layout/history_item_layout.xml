<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="16dp"
    android:background="@drawable/selectable_item_drawable">

    <TextView
        android:id="@+id/note"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:singleLine="true"
        android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
        android:layout_marginEnd="12dp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/amount"
        tools:text="THE DESCRIPTION ABOUT THE TRANSACTION WILL BE HERE" />

    <TextView
        android:id="@+id/amount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="120dp"
        android:singleLine="true"
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
        android:textStyle="bold"
        app:layout_constrainedWidth="true"
        app:layout_constraintTop_toTopOf="@id/note"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="$20,000,000.00" />

    <TextView
        android:id="@+id/label_source"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/note"
        app:layout_constraintStart_toStartOf="parent"
        android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:text="@string/from" />


    <TextView
        android:id="@+id/source"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:singleLine="true"
        android:layout_marginStart="12dp"
        android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/label_source"
        app:layout_constraintBottom_toBottomOf="@id/label_source"
        app:layout_constraintStart_toEndOf="@id/label_source"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="TOO MUCH LONG NAME OF AN ACCOUNT" />

    <TextView
        android:id="@+id/label_destination"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/label_source"
        app:layout_constraintStart_toStartOf="parent"
        android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:visibility="gone"
        android:text="@string/to"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/destination"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:ellipsize="end"
        android:singleLine="true"
        android:layout_marginStart="12dp"
        android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/label_destination"
        app:layout_constraintBottom_toBottomOf="@id/label_destination"
        app:layout_constraintStart_toEndOf="@id/label_destination"
        app:layout_constraintEnd_toEndOf="parent"
        tools:visibility="visible"
        tools:text="THIS IS VERY LONG PERSON NAME THAT MAY NOT FIT THE GIVE AREA" />

    <TextView
        android:id="@+id/type"
        android:layout_width="wrap_content"
        android:layout_height="28dp"
        android:maxWidth="100dp"
        android:singleLine="true"
        android:layout_marginTop="8dp"
        android:padding="8dp"
        android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
        android:textSize="8sp"
        android:textStyle="normal"
        app:layout_constraintTop_toBottomOf="@id/destination"
        app:layout_constraintStart_toStartOf="parent"
        tools:background="@drawable/history_type_credit_background"
        tools:textColor="@color/colorOnCredit"
        tools:text="Credit"
        tools:ignore="SmallSp" />

    <TextView
        android:id="@+id/group"
        android:layout_width="wrap_content"
        android:layout_height="28dp"
        android:maxWidth="100dp"
        android:visibility="invisible"
        android:ellipsize="end"
        android:singleLine="true"
        android:background="@drawable/history_list_item_history_group_background"
        android:layout_marginStart="12dp"
        android:layout_marginTop="8dp"
        android:padding="8dp"
        android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
        android:textSize="8sp"
        android:textColor="?attr/colorOnSecondary"
        app:layout_constraintTop_toBottomOf="@id/destination"
        app:layout_constraintStart_toEndOf="@id/type"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constrainedWidth="true"
        tools:visibility="visible"
        tools:text="Thailand Trip"
        tools:ignore="SmallSp" />

    <com.google.android.material.divider.MaterialDivider
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/type"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

